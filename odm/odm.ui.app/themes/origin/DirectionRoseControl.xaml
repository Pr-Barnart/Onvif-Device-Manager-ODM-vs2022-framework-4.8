<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:odm_ui_controls="clr-namespace:odm.ui.controls;assembly=odm.ui.views">
    <Style TargetType="{x:Type odm_ui_controls:DirectionRoseControl}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type odm_ui_controls:DirectionRoseControl}">
                    <Grid>
                        <Ellipse Height="51" HorizontalAlignment="Left" Margin="27,27,0,0" Stroke="Black" VerticalAlignment="Top" Width="51" />

                        <ToggleButton Cursor="Hand" IsChecked="{TemplateBinding btnDownLeft}" Command="{TemplateBinding btnDownLeftCmd}" Height="23" HorizontalAlignment="Left" Margin="14,68,0,0" VerticalAlignment="Top" Width="23">
                            <ToggleButton.RenderTransform>
                                <RotateTransform Angle="225" CenterX="11.5" CenterY="11.5"/>
                            </ToggleButton.RenderTransform>
                        </ToggleButton>
                        <ToggleButton Cursor="Hand" IsChecked="{TemplateBinding btnRight}" Command="{TemplateBinding btnRightCmd}" Height="23" HorizontalAlignment="Left" Margin="79,41,0,0" VerticalAlignment="Top" Width="23">
                            <ToggleButton.RenderTransform>
                                <RotateTransform Angle="90" CenterX="11.5" CenterY="11.5"/>
                            </ToggleButton.RenderTransform>
                        </ToggleButton>
                        <ToggleButton Cursor="Hand" IsChecked="{TemplateBinding btnDown}" Command="{TemplateBinding btnDownCmd}" Height="23" HorizontalAlignment="Left" Margin="41,79,0,0" VerticalAlignment="Top" Width="23">
                            <ToggleButton.RenderTransform>
                                <RotateTransform Angle="180" CenterX="11.5" CenterY="11.5"/>
                            </ToggleButton.RenderTransform>
                        </ToggleButton>
                        <ToggleButton Cursor="Hand" IsChecked="{TemplateBinding btnLeft}" Command="{TemplateBinding btnLeftCmd}" Height="23" HorizontalAlignment="Left" Margin="3,41,0,0" VerticalAlignment="Top" Width="23">
                            <ToggleButton.RenderTransform>
                                <RotateTransform Angle="270" CenterX="11.5" CenterY="11.5"/>
                            </ToggleButton.RenderTransform>
                        </ToggleButton>
                        <ToggleButton Cursor="Hand" IsChecked="{TemplateBinding btnUp}" Command="{TemplateBinding btnUpCmd}" Height="23" HorizontalAlignment="Left" Margin="41,3,0,0" VerticalAlignment="Top" Width="23">
                            <ToggleButton.RenderTransform>
                                <RotateTransform Angle="0" CenterX="11.5" CenterY="11.5"/>
                            </ToggleButton.RenderTransform>
                        </ToggleButton>
                        <ToggleButton Cursor="Hand" IsChecked="{TemplateBinding btnUpRight}" Command="{TemplateBinding btnUpRightCmd}" Height="23" HorizontalAlignment="Left" Margin="68,14,0,0" VerticalAlignment="Top" Width="23">
                            <ToggleButton.RenderTransform>
                                <RotateTransform Angle="45" CenterX="11.5" CenterY="11.5"/>
                            </ToggleButton.RenderTransform>
                        </ToggleButton>
                        <ToggleButton Cursor="Hand" IsChecked="{TemplateBinding btnDownRight}" Command="{TemplateBinding btnDownRightCmd}" HorizontalAlignment="Left" Margin="68,68,0,0" Width="23" Height="23" VerticalAlignment="Top">
                            <ToggleButton.RenderTransform>
                                <RotateTransform Angle="135" CenterX="11.5" CenterY="11.5"/>
                            </ToggleButton.RenderTransform>
                        </ToggleButton>
                        <ToggleButton Cursor="Hand" IsChecked="{TemplateBinding btnUpLeft}" Command="{TemplateBinding btnUpLeftCmd}" Height="23" HorizontalAlignment="Left" Margin="14,14,0,0" VerticalAlignment="Top" Width="23">
                            <ToggleButton.RenderTransform>
                                <RotateTransform Angle="315" CenterX="11.5" CenterY="11.5"/>
                            </ToggleButton.RenderTransform>
                        </ToggleButton>

                        <Button Command="{TemplateBinding btnAll}" Content="{TemplateBinding captionAll}" Height="23" HorizontalAlignment="Left" Margin="0,106,0,0" VerticalAlignment="Top" Width="50" />
                        <Button Command="{TemplateBinding btnNone}" Content="{TemplateBinding captionNone}" Height="23" HorizontalAlignment="Right" Margin="0,106,0,0" VerticalAlignment="Top" Width="50"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>